<!DOCTYPE html>
<html lang="en">

<head>
     <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>Identity Hub | OAuth & OIDC Provider</title>
     <style>
          :root {
               --primary-bg: #f3f4f6;
               --accent-color: #4f46e5;
               --accent-hover: #4338ca;
               --text-dark: #111827;
               --text-gray: #6b7280;
               --card-bg: #ffffff;
               --border: #e5e7eb;
          }

          body {
               font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
               background-color: var(--primary-bg);
               margin: 0;
               color: var(--text-dark);
               line-height: 1.6;
          }

          /* Hero Section */
          .hero {
               display: flex;
               flex-direction: column;
               align-items: center;
               justify-content: center;
               text-align: center;
               padding: 80px 20px;
               min-height: 80vh;
          }

          .badge {
               background: rgba(79, 70, 229, 0.1);
               color: var(--accent-color);
               padding: 8px 16px;
               border-radius: 20px;
               font-size: 0.85rem;
               font-weight: 600;
               margin-bottom: 20px;
          }

          h1 {
               font-size: 3rem;
               margin: 0 0 20px 0;
               font-weight: 800;
               letter-spacing: -0.02em;
          }

          p.description {
               max-width: 600px;
               font-size: 1.125rem;
               color: var(--text-gray);
               margin-bottom: 40px;
          }

          /* Action Buttons */
          .cta-group {
               display: flex;
               gap: 15px;
               flex-wrap: wrap;
               justify-content: center;
          }

          .btn {
               padding: 12px 28px;
               border-radius: 8px;
               font-size: 1rem;
               font-weight: 600;
               text-decoration: none;
               transition: all 0.2s;
          }

          .btn-primary {
               background-color: var(--accent-color);
               color: white;
          }

          .btn-primary:hover {
               background-color: var(--accent-hover);
          }

          .btn-outline {
               background-color: white;
               color: var(--text-dark);
               border: 1px solid var(--border);
          }

          .btn-outline:hover {
               background-color: #fafafa;
               border-color: #d1d5db;
          }

          /* Features Grid */
          .features {
               display: grid;
               grid-template-columns: repeat(auto-fit, min-max(250px, 1fr));
               gap: 20px;
               max-width: 1000px;
               width: 100%;
               margin-top: 60px;
          }

          .feature-card {
               background: var(--card-bg);
               padding: 24px;
               border-radius: 12px;
               border: 1px solid var(--border);
               text-align: left;
          }

          .feature-card h3 {
               margin: 0 0 10px 0;
               font-size: 1.1rem;
          }

          .feature-card p {
               margin: 0;
               font-size: 0.9rem;
               color: var(--text-gray);
          }
     </style>
</head>

<body>

     <section class="hero">
          <span class="badge">OpenID Certified</span>
          <h1>Your Secure Identity Provider</h1>
          <p class="description">
               A custom-built OAuth 2.0 and OpenID Connect provider designed for modularity and industry-standard
               security. Connect your apps seamlessly.
          </p>

          <div class="cta-group">
               <a href="/auth/login" class="btn btn-primary">Sign In</a>
               <a href="/auth/register" class="btn btn-outline">Create Account</a>
               <a href="/client/register" class="btn btn-outline">Register App</a>
          </div>

          <div class="features">
               <div class="feature-card">
                    <h3>OAuth 2.0</h3>
                    <p>Support for Authorization Code and Implicit flows.</p>
               </div>
               <div class="feature-card">
                    <h3>OIDC Support</h3>
                    <p>Standardized identity layer for user verification.</p>
               </div>
               <div class="feature-card">
                    <h3>Secure APIs</h3>
                    <p>Protected resource endpoints using JWT Bearer tokens.</p>
               </div>
          </div>
     </section>

</body>

</html>