<!DOCTYPE html>
<html lang="en">

<head>
     <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>Register Client</title>
     <style>
          /* Consistent Design System */
          :root {
               --primary-bg: #f3f4f6;
               --accent-color: #4f46e5;
               --accent-hover: #4338ca;
               --text-dark: #111827;
               --text-gray: #6b7280;
               --card-bg: #ffffff;
               --border: #e5e7eb;
          }

          body {
               font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
               background-color: var(--primary-bg);
               margin: 0;
               display: flex;
               align-items: center;
               justify-content: center;
               min-height: 100vh;
          }

          .card {
               background: var(--card-bg);
               padding: 2.5rem;
               border-radius: 12px;
               box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
               width: 100%;
               max-width: 400px;
               border: 1px solid var(--border);
          }

          h2 {
               margin-top: 0;
               color: var(--text-dark);
               font-size: 1.5rem;
               text-align: center;
               margin-bottom: 0.5rem;
          }

          p.subtitle {
               text-align: center;
               color: var(--text-gray);
               font-size: 0.9rem;
               margin-bottom: 1.5rem;
          }

          .form-group {
               margin-bottom: 1.25rem;
          }

          input {
               width: 100%;
               padding: 0.75rem;
               border: 1px solid var(--border);
               border-radius: 8px;
               box-sizing: border-box;
               font-size: 1rem;
               transition: border-color 0.2s, box-shadow 0.2s;
          }

          input:focus {
               outline: none;
               border-color: var(--accent-color);
               box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
          }

          button {
               width: 100%;
               padding: 0.75rem;
               background-color: var(--accent-color);
               color: white;
               border: none;
               border-radius: 8px;
               font-size: 1rem;
               font-weight: 600;
               cursor: pointer;
               transition: background-color 0.2s;
               margin-top: 0.5rem;
          }

          button:hover {
               background-color: var(--accent-hover);
          }

          .back-link {
               display: block;
               text-align: center;
               margin-top: 1.5rem;
               font-size: 0.875rem;
               color: var(--text-gray);
               text-decoration: none;
          }

          .back-link:hover {
               color: var(--accent-color);
          }
     </style>
</head>

<body>

     <div class="card">
          <h2>Register Client</h2>
          <p class="subtitle">Set up a new application client</p>

          <form method="POST" action="/client/register">
               <div class="form-group">
                    <input name="name" type="text" placeholder="App Name" required />
               </div>

               <div class="form-group">
                    <input name="redirectUri" type="url" placeholder="Redirect URI (https://...)" required />
               </div>

               <button type="submit">Create Client</button>
          </form>

          <a href="/" class="back-link">← Back to Dashboard</a>
     </div>

</body>

</html>